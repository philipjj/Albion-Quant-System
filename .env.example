# Albion Quant Trading System - Environment Variables

# Database
DATABASE_URL=sqlite:///./data/albion_quant.db
# For PostgreSQL production:
# DATABASE_URL=postgresql://user:password@localhost:5432/albion_quant

# Albion API
ALBION_API_BASE=https://west.albion-online-data.com
ALBION_API_SERVER=west

# Discord Alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Trading Parameters
MIN_ARBITRAGE_MARGIN=12.0
MIN_ARBITRAGE_PROFIT=10000
MIN_CRAFTING_PROFIT=5000
MIN_VOLUME=5

# Market Constants
PREMIUM_TAX_RATE=0.04
NON_PREMIUM_TAX_RATE=0.08
SETUP_FEE_RATE=0.025
IS_PREMIUM=true

# Scheduler
MARKET_POLL_INTERVAL_MINUTES=5
ARBITRAGE_COMPUTE_INTERVAL_MINUTES=10
CRAFTING_COMPUTE_INTERVAL_MINUTES=10
SNAPSHOT_INTERVAL_MINUTES=60

# Logging
LOG_LEVEL=INFO

# Tests / CI: set to true to skip scheduler, Discord bot, and startup collection
# DISABLE_BACKGROUND_TASKS=false
